# TechnoPath PWA Environment Configuration

# OpenAI API Key for AI-powered chatbot
# Get your API key from: https://platform.openai.com/api-keys
# Then copy this file to .env and add your key
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Django Backend URL (defaults to /api via proxy in dev)
VITE_API_BASE_URL=/api

# Flask Chatbot Service URL
VITE_FLASK_CHATBOT_URL=http://localhost:5187
